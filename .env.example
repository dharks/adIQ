APP_NAME=AdIQ
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.adiq.io

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=adiq
DB_USERNAME=adiq_user
DB_PASSWORD=your_secure_password

SESSION_DRIVER=database
SESSION_LIFETIME=120

# Google OAuth2 credentials (from Google Cloud Console)
# Required for the GAM connection proxy
GAM_CLIENT_ID=your-client-id.apps.googleusercontent.com
GAM_CLIENT_SECRET=your-client-secret
GAM_OAUTH_REDIRECT_URI=${APP_URL}/oauth/gam/callback
